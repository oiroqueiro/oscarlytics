DOMAIN=yourdomain.com
DB_NAME=portfolio_db
DB_USER=postg_user
DB_PASSWORD=your_db_password
SECRET_KEY=your_secret_key
MEILI_MASTER_KEY=your_meili_master_key
DATABASE_URL=postgresql://postg_user:your_db_password@localhost:5432/portfolio_db
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_MASTER_KEY=your_meili_master_key

# ==========================================
# GITHUB CONTAINER REGISTRY (GHCR)
# ==========================================
GHCR_REGISTRY=ghcr.io/your-github-username

# Admin User Defaults
ADMIN_USER=admin
ADMIN_PASSWORD=your_secure_admin_password

# Email configs
MAIL_SERVER=smtp.example.com
MAIL_PORT=465
MAIL_USE_SSL=True
MAIL_USE_TLS=False
MAIL_USERNAME=email@example.com
MAIL_PASSWORD=your_email_password
MAIL_RECIPIENT=recipient@example.com

# ReCaptcha and Third-party keys
GOOGLE_TAGMANAGER_KEY=your_google_tagmanager_key
RECAPTCHA_SITE_KEY=your_recaptcha_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key
DuckDNS_Token=your_duckdns_token

# App preferences
PORTFOLIO_LOGIN_URL=manage
PORTFOLIO_LOGOUT_URL=theend
PROJECTS_PAGE=4

# --- Paths and Directories ---
# Absolute path to host directory containing static images/logos on the VPS/host
PORTFOLIO_IMG_DIR=/path/to/your/portfolio/data/portfolio_img

